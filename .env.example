# Database (PostgreSQL) — Prisma reads these via `dotenv -e .env.local` in npm db:* scripts
# For direct Postgres (Dokploy, local Docker, etc.), set both URLs to the same connection string.
# Only add ?pgbouncer=true to DATABASE_URL if you actually use a transaction pooler (e.g. Supabase :6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Cloudflare R2 — guided photo uploads (Pushduck)
# Create an R2 API token with Object Read & Write on your bucket.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION=auto

# Set to "true" when R2 credentials above are configured (enables client-side direct upload UI).
NEXT_PUBLIC_R2_UPLOAD_ENABLED=false

# Optional — Google Maps Embed API key for listing location maps (recommended for production).
# Without this, maps still work via a basic Google Maps iframe using the airfield/location text.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
