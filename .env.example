# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aviatonly?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"

# OAuth (optional — configure when enabling social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Object storage (optional — configure when enabling uploads)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# AI demo routes in dashboard template (optional)
# GOOGLE_GENERATIVE_AI_API_KEY=
