// AVIATONLY — starter schema. Extend as domain models are implemented.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ListingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CHANGES
  VALUATION_READY
  INSPECTION_PENDING
  INSPECTION_PASSED
  INSPECTION_FAILED
  LIVE_FIXED_PRICE
  LIVE_AUCTION
  UNDER_OFFER
  DEPOSIT_PENDING
  UNDER_CONTRACT
  SACAA_TRANSFER_PENDING
  SOLD
  WITHDRAWN
  EXPIRED
}

enum SaleType {
  FIXED_PRICE
  AUCTION
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings AircraftListing[]
}

model AircraftListing {
  id               String   @id @default(cuid())
  registration     String   @unique
  registrationType String
  make             String
  model            String
  year             Int
  category         String
  airfield         String
  province         String

  // Technical
  ttaf               Float?
  engineMakeModel    String?
  engineHours        Float?
  tso                Float?
  propellerMakeModel String?
  propellerHours     Float?
  avionics           String?
  maintenanceStatus  String?
  lastMpiDate        DateTime?
  knownDefects       String?

  // Pricing (ZAR, whole rand)
  saleType          SaleType @default(FIXED_PRICE)
  valuationEstimate Int?
  askingPrice       Int?
  reservePrice      Int?
  startingBid       Int?
  bidIncrement      Int?

  status    ListingStatus @default(DRAFT)
  sellerId  String
  seller    User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  photos    AircraftPhoto[]
  documents AircraftDocument[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([sellerId])
}

model AircraftPhoto {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  slot      String
  fileName  String
  createdAt DateTime        @default(now())

  @@index([listingId])
}

model AircraftDocument {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  slot      String
  fileName  String
  createdAt DateTime        @default(now())

  @@index([listingId])
}
