// AVIATONLY — starter schema. Extend as domain models are implemented.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CHANGES
  VALUATION_READY
  INSPECTION_PENDING
  INSPECTION_PASSED
  INSPECTION_FAILED
  LIVE_FIXED_PRICE
  LIVE_AUCTION
  UNDER_OFFER
  DEPOSIT_PENDING
  UNDER_CONTRACT
  SACAA_TRANSFER_PENDING
  SOLD
  WITHDRAWN
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings AircraftListing[]
}

model AircraftListing {
  id             String        @id @default(cuid())
  registration   String        @unique
  registrationType String
  make           String
  model          String
  year           Int
  status         ListingStatus @default(DRAFT)
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([sellerId])
}
