// AVIATONLY — domain schema.
//
// Design notes:
// - The aircraft listing is a workflow object, not a flat row. Technical detail
//   lives in child/domain records (airframe, engines, propellers, avionics,
//   maintenance) instead of one giant nullable table.
// - Every status change is recorded in ListingStatusHistory; the activity
//   timeline is driven by ListingEvent.
// - Photos and documents carry their own review status; documents are private
//   by default via DocumentVisibility.
// - Actor references (changedById, actorId, uploadedById, ...) are scalar IDs
//   for now and become real User relations when auth + roles land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ListingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CHANGES
  VALUATION_READY
  INSPECTION_PENDING
  INSPECTION_PASSED
  INSPECTION_FAILED
  APPROVED_FOR_LISTING
  LIVE_FIXED_PRICE
  LIVE_AUCTION
  UNDER_OFFER
  DEPOSIT_PENDING
  UNDER_CONTRACT
  TRANSFER_PENDING
  SOLD
  WITHDRAWN
  EXPIRED
}

enum SaleType {
  FIXED_PRICE
  AUCTION
}

enum EnginePosition {
  SINGLE
  LEFT
  RIGHT
  FRONT
  REAR
}

enum PropellerType {
  FIXED_PITCH
  CONSTANT_SPEED
  VARIABLE_PITCH
  OTHER
}

enum PhotoStatus {
  EMPTY
  UPLOADING
  UPLOADED
  PROCESSING
  READY
  APPROVED
  REJECTED
  NEEDS_REPLACEMENT
}

enum DocumentStatus {
  MISSING
  UPLOADED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  EXPIRED
  NEEDS_REPLACEMENT
}

enum DocumentVisibility {
  PRIVATE_INTERNAL
  AVAILABLE_ON_REQUEST
  SHARED_WITH_VERIFIED_BUYER
  PUBLIC_SUMMARY_ONLY
}

enum ReviewTaskStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_SELLER
  WAITING_ON_ADMIN
  DONE
  CANCELLED
}

enum FieldReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadType {
  GENERAL_ENQUIRY
  VIEWING_REQUEST
  DOCUMENT_ACCESS
  DEMO_FLIGHT
  FINANCE_ENQUIRY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  VIEWING_REQUESTED
  OFFER_MADE
  CLOSED
}

enum LeadSource {
  PUBLIC_LISTING
  BROKER_REFERRAL
  AUCTION
  ADMIN
}

enum LeadPriority {
  LOW
  NORMAL
  HIGH
}

enum BuyerVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum LeadActivityType {
  NOTE_ADDED
  STATUS_CHANGED
  ASSIGNED
  EMAIL_SENT
  CALL_LOGGED
  VIEWING_SCHEDULED
  DOC_ACCESS_GRANTED
  DOC_ACCESS_DENIED
  COUNTER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  FOLLOW_UP_SET
  LEAD_CREATED
}

enum OfferStatus {
  RECEIVED
  UNDER_REVIEW
  SELLER_COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum OfferActivityType {
  NOTE_ADDED
  STATUS_CHANGED
  COUNTER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_CREATED
  OFFER_WITHDRAWN
}

enum DealStatus {
  OFFER_ACCEPTED
  DEPOSIT_PENDING
  DEPOSIT_CONFIRMED
  CONTRACT_PENDING
  CONTRACT_SIGNED
  INSPECTION_WINDOW
  TRANSFER_DOCUMENTS_PENDING
  SACAA_TRANSFER_PENDING
  FUNDS_RELEASE_PENDING
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Core
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  roles         String[]  @default(["SELLER"])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  listings AircraftListing[]
  members     Member[]
  invitations Invitation[]

  buyerLeads       Lead[]         @relation("LeadBuyer")
  sellerLeads      Lead[]         @relation("LeadSeller")
  assignedLeads    Lead[]         @relation("LeadAssignee")
  buyerOffers      Offer[]        @relation("OfferBuyer")
  sellerOffers     Offer[]        @relation("OfferSeller")
  counteredOffers  Offer[]        @relation("OfferCounteredBy")
  reviewedOffers   Offer[]        @relation("OfferReviewedBy")
  buyerDeals       Deal[]         @relation("DealBuyer")
  sellerDeals      Deal[]         @relation("DealSeller")
  leadActivities   LeadActivity[]
  offerActivities  OfferActivity[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  metadata         String?
  organizationType String?  @default("SELLER")
  province         String?
  createdAt        DateTime @default(now())

  members     Member[]
  invitations Invitation[]
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model AircraftListing {
  id String @id @default(cuid())

  // Identity
  registration     String @unique
  registrationType String
  make             String
  model            String
  year             Int
  category         String
  airfield         String
  province         String

  // Ownership & seller details
  ownerName        String?
  sellerRole       String?
  authorisedToSell Boolean?

  // Pricing & sale setup (ZAR, whole rand)
  saleType          SaleType @default(FIXED_PRICE)
  valuationEstimate Int?
  askingPrice       Int?
  reservePrice      Int?
  startingBid       Int?
  bidIncrement      Int?

  // Workflow
  status            ListingStatus @default(DRAFT)
  completenessScore Int           @default(0)
  intakeReviewFinalizedAt   DateTime?
  intakeReviewTasksReleasedAt DateTime?

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  // Domain child records
  airframe    AircraftAirframe?
  avionics    AircraftAvionics?
  maintenance AircraftMaintenance?
  engines     AircraftEngine[]
  propellers  AircraftPropeller[]
  photos      AircraftPhoto[]
  documents   AircraftDocument[]

  // Workflow records
  statusHistory ListingStatusHistory[]
  events        ListingEvent[]
  reviewTasks   ListingReviewTask[]
  fieldReviews  ListingFieldReview[]
  leads         Lead[]
  offers        Offer[]
  deals         Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sellerId])
}

// Holds in-progress wizard data so sellers can autosave and resume an aircraft
// intake before it becomes a real AircraftListing on submission.
model ListingDraft {
  id        String   @id @default(cuid())
  data      Json
  step      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Aircraft domain child records
// ---------------------------------------------------------------------------

model AircraftAirframe {
  id        String          @id @default(cuid())
  listingId String          @unique
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  serialNumber     String?
  totalTimeAirframe Float? // TTAF (hours)
  damageHistory    String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AircraftEngine {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  position             EnginePosition @default(SINGLE)
  manufacturer         String?
  model                String?
  serialNumber         String?
  horsepowerOrThrust   String?
  engineHours          Float?
  timeSinceOverhaul    Float?
  timeSinceNew         Float?
  overhaulDate         DateTime?
  overhaulFacility     String?
  calendarLifeRemaining String?
  knownIssues          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

model AircraftPropeller {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  manufacturer      String?
  model             String?
  serialNumber      String?
  bladeCount        Int?
  propellerType     PropellerType?
  propellerHours    Float?
  timeSinceOverhaul Float?
  overhaulDate      DateTime?
  knownDamageNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

model AircraftAvionics {
  id        String          @id @default(cuid())
  listingId String          @unique
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // Common installed equipment (checkbox selections) plus free-text extras.
  equipment String[]
  summary   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AircraftMaintenance {
  id        String          @id @default(cuid())
  listingId String          @unique
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  status      String?
  lastMpiDate DateTime?
  nextMpiDue  DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Media & documents
// ---------------------------------------------------------------------------

model AircraftPhoto {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  slotKey   String
  fileName  String
  mimeType  String?
  sizeBytes Int?
  storageKey String?
  publicUrl String?

  status          PhotoStatus @default(UPLOADED)
  rejectionReason String?

  uploadedById String?
  reviewedById String?
  uploadedAt   DateTime  @default(now())
  reviewedAt   DateTime?

  sortOrder           Int     @default(0)
  isPublicGalleryImage Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

model AircraftDocument {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  documentType String // slot key, e.g. "mpi-stamp", "cor"
  fileName     String
  mimeType     String?
  sizeBytes    Int?
  storageKey   String?

  reviewStatus    DocumentStatus     @default(UPLOADED)
  visibility      DocumentVisibility @default(PRIVATE_INTERNAL)
  rejectionReason String?

  uploadedById String?
  reviewedById String?
  uploadedAt   DateTime  @default(now())
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Workflow: status history, events, review tasks
// ---------------------------------------------------------------------------

model ListingStatusHistory {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  fromStatus  ListingStatus?
  toStatus    ListingStatus
  changedById String?
  reason      String?

  createdAt DateTime @default(now())

  @@index([listingId])
}

model ListingEvent {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  actorId  String?
  type     String // e.g. SELLER_SUBMITTED_LISTING, DOCUMENT_REJECTED, OFFER_RECEIVED
  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([listingId])
}

model ListingReviewTask {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  title       String
  description String?

  assignedToId String?
  assignedRole String?
  status       ReviewTaskStatus @default(OPEN)
  dueDate      DateTime?

  blockingPublication Boolean @default(false)
  releasedToSeller    Boolean @default(false)

  sourceType String? // field | photo | document
  sourceKey  String?

  createdById String?
  resolvedById String?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

model ListingFieldReview {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  fieldKey String
  label    String
  status   FieldReviewStatus @default(PENDING)

  rejectionReason String?
  rejectionPreset String?

  reviewedById String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, fieldKey])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Leads, offers, deals (CRM workflow)
// ---------------------------------------------------------------------------

model Lead {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId  String
  buyer    User   @relation("LeadBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId String
  seller   User   @relation("LeadSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  type     LeadType
  status   LeadStatus     @default(NEW)
  source   LeadSource     @default(PUBLIC_LISTING)
  priority LeadPriority   @default(NORMAL)

  message                 String
  buyerVerificationStatus BuyerVerificationStatus @default(UNVERIFIED)
  internalNotes           String?

  assignedToId String?
  assignee     User?   @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  nextFollowUpAt  DateTime?
  lastContactedAt DateTime?

  convertedOfferId String? @unique
  convertedOffer   Offer?  @relation("LeadConvertedOffer", fields: [convertedOfferId], references: [id], onDelete: SetNull)

  closedReason String?

  activities LeadActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([assignedToId])
  @@index([nextFollowUpAt])
}

model LeadActivity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  type     LeadActivityType
  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model Offer {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId  String
  buyer    User   @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId String
  seller   User   @relation("OfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  amount   Int
  currency String      @default("ZAR")
  message  String?
  status   OfferStatus @default(RECEIVED)

  expiresAt DateTime?

  counterAmount  Int?
  counterMessage String?
  counteredAt    DateTime?
  counteredById  String?
  counteredBy    User?     @relation("OfferCounteredBy", fields: [counteredById], references: [id], onDelete: SetNull)

  conditions Json?

  reviewedById String?
  reviewedBy   User?     @relation("OfferReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?

  deal Deal?

  convertedFromLead Lead? @relation("LeadConvertedOffer")

  activities OfferActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
}

model OfferActivity {
  id      String @id @default(cuid())
  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  type     OfferActivityType
  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([offerId])
  @@index([createdAt])
}

model Deal {
  id        String          @id @default(cuid())
  listingId String
  listing   AircraftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId  String
  buyer    User   @relation("DealBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId String
  seller   User   @relation("DealSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  acceptedOfferId String @unique
  offer           Offer  @relation(fields: [acceptedOfferId], references: [id], onDelete: Restrict)

  agreedPrice      Int
  currency         String     @default("ZAR")
  depositAmount    Int?
  commissionAmount Int?
  vatAmount        Int?
  status           DealStatus @default(OFFER_ACCEPTED)
  nextAction       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}
